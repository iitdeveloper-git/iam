#
# IITD IAM local Docker defaults.
# Copy this file to .env and run `make start`.
# These values are development-only; replace them for any shared environment.
#

# Shared local service passwords
IAM_POSTGRES_PASSWORD=iam-local-password
KEYCLOAK_DB_PASSWORD=keycloak-local-password
KEYCLOAK_ADMIN=admin
KEYCLOAK_ADMIN_PASSWORD=admin

# Backend / FastAPI
IAM_ENVIRONMENT=local
IAM_DATABASE_URL=postgresql://iam:iam-local-password@postgres:5432/iam
IAM_REDIS_URL=redis://redis:6379/0
IAM_KEYCLOAK_BASE_URL=http://keycloak:8080
IAM_OIDC_ISSUER=http://localhost:8080/realms/iitd
IAM_OIDC_JWKS_URL=http://keycloak:8080/realms/iitd/protocol/openid-connect/certs
IAM_OIDC_AUDIENCE=account
IAM_OIDC_ALLOWED_AUTHORIZED_PARTIES=["iitd-iam-admin"]
IAM_CORS_ORIGINS=["http://localhost:3030"]
IAM_COOKIE_SECURE=false
IAM_ALLOW_DEV_AUTH=true

# Frontend / Next.js Auth.js
NEXT_PUBLIC_IAM_API_URL=http://localhost:8000/api/v1
NEXT_PUBLIC_ENABLE_UAT_TOKEN_FALLBACK=true
AUTH_SECRET=local-dev-secret-change-in-production
AUTH_URL=http://localhost:3030
AUTH_IITD_ISSUER=http://keycloak:8080/realms/iitd
AUTH_IITD_PUBLIC_ISSUER=http://localhost:8080/realms/iitd
AUTH_IITD_CLIENT_ID=iitd-iam-admin
# Public client locally; leave unset unless you make the Keycloak client confidential.
# AUTH_IITD_CLIENT_SECRET=

# Local Keycloak container
KC_DB=postgres
KC_DB_URL=jdbc:postgresql://keycloak-db:5432/keycloak
KC_DB_USERNAME=keycloak
KC_DB_PASSWORD=keycloak-local-password
KC_HTTP_ENABLED=true
KC_HTTP_PORT=8080
KC_HOSTNAME=http://localhost:8080
KC_HOSTNAME_STRICT=false
KC_HOSTNAME_STRICT_BACKCHANNEL=false
KC_PROXY_HEADERS=xforwarded

# Hugging Face / production reference values:
# IAM_KEYCLOAK_BASE_URL=https://iitdeveloper-keycloak.hf.space
# IAM_OIDC_ISSUER=https://iitdeveloper-keycloak.hf.space/realms/iitd
# IAM_OIDC_JWKS_URL=https://iitdeveloper-keycloak.hf.space/realms/iitd/protocol/openid-connect/certs
# IAM_DATABASE_URL=postgresql+asyncpg://postgres.wlscfgajthpkvxsuewuw:<SUPABASE_PASSWORD>@aws-1-ap-southeast-1.pooler.supabase.com:5432/postgres?ssl=require
# KC_DB_URL=jdbc:postgresql://aws-1-ap-southeast-1.pooler.supabase.com:6543/postgres?sslmode=require&prepareThreshold=0&currentSchema=keycloak
# KC_DB_USERNAME=postgres.wlscfgajthpkvxsuewuw
